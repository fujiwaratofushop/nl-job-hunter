# Generate a random string for this — e.g. run in PowerShell:
# -join ((65..90) + (97..122) + (48..57) | Get-Random -Count 32 | % {[char]$_})
N8N_ENCRYPTION_KEY=change_me_to_a_random_32char_string

# Your Apify API token — get it from https://console.apify.com/account/integrations
APIFY_API_TOKEN=change_me_to_appify_api_token

# llama.cpp server URL — default assumes it's running on host port 8080
# If using a different port, change it here
LLAMA_CPP_URL=change_me_to_llama_cpp_server_url

# Google Sheet ID — get it from the URL of your Google Sheet
GOOGLE_SHEET_ID=change_me_to_google_sheet_id